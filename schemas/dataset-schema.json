{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ech09527/quant-factors/schemas/dataset-schema.json",
  "title": "DatasetSchema",
  "description": "定义 datasets/<slug>/schema.json 的格式，由 Kaggle 探索 Kernel 产出",
  "type": "object",
  "required": ["slug", "explored_at", "files"],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$",
      "description": "Kaggle 数据集 slug，格式 owner/dataset-name"
    },
    "explored_at": {
      "type": "string",
      "format": "date-time",
      "description": "最后一次 Kaggle 探索完成时间（ISO 8601）"
    },
    "kaggle_version": {
      "type": ["string", "null"],
      "description": "Kaggle 数据集版本号，便于追踪列或格式变更"
    },
    "input_path": {
      "type": "string",
      "description": "Kaggle Kernel 中实际数据集挂载路径"
    },
    "expected_input_path": {
      "type": "string",
      "description": "按 slug 约定的标准挂载路径（owner-name）"
    },
    "catalog_summary": {
      "type": "object",
      "description": "数据集目录级摘要",
      "additionalProperties": false,
      "properties": {
        "file_tree": {
          "type": "array",
          "items": { "type": "string" },
          "description": "数据文件相对路径列表"
        },
        "data_file_count": {
          "type": "integer",
          "minimum": 0
        },
        "inferred_kind": {
          "type": "string",
          "description": "根据路径推断的数据类型说明"
        },
        "symbol_count_in_sample": {
          "type": "integer",
          "minimum": 0,
          "description": "抽样中的 symbol 唯一数"
        },
        "total_row_count": {
          "type": "integer",
          "minimum": 0,
          "description": "全量行数（parquet 元数据或聚合）"
        },
        "symbol_count_full": {
          "type": "integer",
          "minimum": 0,
          "description": "全量 symbol 唯一数"
        },
        "date_range_full": {
          "type": "object",
          "description": "全量时间范围",
          "additionalProperties": false,
          "properties": {
            "column": { "type": "string" },
            "start": { "type": "string" },
            "end": { "type": "string" },
            "unit": { "type": "string" }
          }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "description": "数据集中各文件的列级元数据",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "文件名（含扩展名）"
          },
          "size_bytes": {
            "type": ["integer", "null"],
            "minimum": 0,
            "description": "文件大小（字节）"
          },
          "row_count": {
            "type": ["integer", "null"],
            "minimum": 0,
            "description": "抽样或全量行数"
          },
          "sample_rows": {
            "type": ["integer", "null"],
            "minimum": 0,
            "description": "与 row_count 相同，明确为抽样行数"
          },
          "symbol_count_in_sample": {
            "type": ["integer", "null"],
            "minimum": 0,
            "description": "抽样中 symbol 列唯一值数量"
          },
          "columns": {
            "type": "array",
            "description": "列名与类型统计",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "dtype": { "type": "string" },
                "null_rate": {
                  "type": ["number", "null"],
                  "minimum": 0,
                  "maximum": 1
                },
                "sample_values": {
                  "type": "array",
                  "items": {}
                }
              }
            }
          }
        }
      }
    },
    "date_range": {
      "type": ["object", "null"],
      "description": "数据时间跨度（若可识别）",
      "additionalProperties": false,
      "properties": {
        "column": {
          "type": "string",
          "description": "用于推断时间范围的列名"
        },
        "start": {
          "type": "string",
          "description": "起始日期（ISO 8601 或 YYYY-MM-DD）"
        },
        "end": {
          "type": "string",
          "description": "结束日期（ISO 8601 或 YYYY-MM-DD）"
        },
        "unit": {
          "type": "string",
          "description": "时间列解析单位，如 epoch_ms、epoch_s、datetime"
        }
      }
    },
    "primary_keys": {
      "type": "array",
      "items": { "type": "string" },
      "description": "建议的主键或表间 join 键（如 ticker, date）"
    },
    "factor_field_candidates": {
      "type": "array",
      "items": { "type": "string" },
      "description": "可能用于因子计算的数值或分类字段候选"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "数据质量、缺失、幸存者偏差或使用限制等警告"
    }
  }
}
