# 仓库级环境变量示例
# 复制为 project.env 或在 GitHub Actions Secrets 中配置对应项（勿将真实凭证提交到仓库）

# GitHub Project 数字 ID（Project 设置页 URL 或 GraphQL 查询获取）
# 工作流 B 用于 addProjectV2DraftIssue 等 GraphQL 写入
# 当前仓库关联 Project 见 config/github-project.json
GITHUB_PROJECT_ID=PVT_kwHOCuXpt84Bb4qu

# 仓库所有者（用户或 organization 登录名）
# 用于拼接 Project GraphQL node ID 与 Kaggle Kernel slug
GITHUB_REPOSITORY_OWNER=

# Kaggle 探索 Kernel 的 slug（不含用户名前缀）
# 工作流 A 通过 kaggle kernels push/pull 调用，完整路径为 <owner>/<slug>
KAGGLE_KERNEL_SLUG=explore-dataset

# --- 以下凭证仅通过 GitHub Actions Secrets 配置，勿写入仓库 ---
#
# KAGGLE_API_TOKEN（推荐，见 Vault kv/kaggle/default）
# 或 KAGGLE_USERNAME / KAGGLE_KEY（旧版 API）
#
# CURSOR_AUTH_JSON
#   工作流 B：Cursor CLI 认证。将本地 ~/.config/cursor/auth.json 的完整 JSON 存入此 Secret；
#   workflow 运行 scripts/setup_cursor_auth.sh 写入 runner 的 ~/.config/cursor/auth.json
#
# PROJECT_PAT（或 fine-grained PAT）
#   GitHub Project GraphQL 读写；默认 GITHUB_TOKEN 对 Project 权限可能不足
#
# AI_WORKFLOW_DISPATCH_TOKEN
#   已由 relay-forward.yml 使用，转发 Issue 事件至 ai-workflow（与本需求无直接依赖）
