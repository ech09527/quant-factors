{
  "version": "1",
  "dialect": "duckdb-factor-v1",
  "evaluation_type": "cross_sectional",
  "data_source": "yhydev97/quant-data",
  "signal_sql": "AVG((taker_buy_volume / (volume + 1e-8)) - ((quote_volume / (volume + 1e-8) - low) / (high - low + 1e-8))) OVER (w ROWS BETWEEN 2 PRECEDING AND CURRENT ROW)",
  "postprocess": "cs_rank",
  "universe": {
    "dropna": [
      "open",
      "high",
      "low",
      "close",
      "volume",
      "quote_volume",
      "taker_buy_volume"
    ],
    "min_symbol_bars": 168,
    "cs_quantile_gte": {
      "col": "quote_volume",
      "q": 0.2
    }
  }
}
