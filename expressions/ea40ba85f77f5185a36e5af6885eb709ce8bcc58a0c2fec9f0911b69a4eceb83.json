{
  "version": "1",
  "dialect": "duckdb-factor-v1",
  "evaluation_type": "cross_sectional",
  "data_source": "yhydev97/quant-data",
  "signal_sql": "SIGN(close / LAG(close, 6) OVER w - 1) * (1 - quote_volume / (AVG(quote_volume) OVER (w ROWS BETWEEN 23 PRECEDING AND CURRENT ROW) + 1e-8))",
  "postprocess": "cs_rank",
  "universe": {
    "dropna": [
      "open",
      "high",
      "low",
      "close",
      "quote_volume"
    ],
    "min_symbol_bars": 168,
    "cs_quantile_gte": {
      "col": "quote_volume",
      "q": 0.2
    }
  }
}
