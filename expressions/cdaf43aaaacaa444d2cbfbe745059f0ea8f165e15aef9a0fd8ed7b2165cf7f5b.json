{
  "version": "1",
  "dialect": "duckdb-factor-v1",
  "evaluation_type": "cross_sectional",
  "data_source": "yhydev97/quant-data",
  "signal_sql": "(quote_volume / GREATEST(count, 1.0)) - (count / GREATEST(quote_volume, 1e-8))",
  "postprocess": "cs_zscore",
  "universe": {
    "dropna": [
      "open",
      "high",
      "low",
      "close"
    ],
    "min_symbol_bars": 168,
    "cs_quantile_gte": {
      "col": "quote_volume",
      "q": 0.2
    }
  }
}
