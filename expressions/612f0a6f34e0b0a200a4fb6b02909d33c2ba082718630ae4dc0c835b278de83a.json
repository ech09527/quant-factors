{
  "version": "1",
  "dialect": "duckdb-factor-v1",
  "evaluation_type": "cross_sectional",
  "data_source": "yhydev97/quant-data",
  "signal_sql": "((high - low) / close) / (quote_volume / (AVG(quote_volume) OVER (w ROWS BETWEEN 23 PRECEDING AND CURRENT ROW) + 1e-8) + 1e-8)",
  "postprocess": "cs_rank",
  "universe": {
    "dropna": [
      "open",
      "high",
      "low",
      "close",
      "quote_volume"
    ],
    "min_symbol_bars": 48,
    "cs_quantile_gte": {
      "col": "quote_volume",
      "q": 0.2
    }
  }
}
