{
  "version": "1",
  "dialect": "duckdb-factor-v1",
  "evaluation_type": "cross_sectional",
  "data_source": "yhydev97/quant-data",
  "signal_sql": "(close - open) / (high - low + 1e-8)",
  "postprocess": "cs_rank",
  "universe": {
    "dropna": [
      "open",
      "high",
      "low",
      "close"
    ],
    "min_symbol_bars": 168,
    "cs_quantile_gte": {
      "col": "quote_volume",
      "q": 0.5
    }
  }
}
