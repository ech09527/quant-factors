{
  "version": "1",
  "dialect": "duckdb-factor-v1",
  "evaluation_type": "cross_sectional",
  "data_source": "yhydev97/quant-data",
  "signal_sql": "LN((volume + 1e-8) / (LAG(volume, 1) OVER w + 1e-8)) - LN((count + 1e-8) / (LAG(count, 1) OVER w + 1e-8))",
  "postprocess": "cs_rank",
  "universe": {
    "dropna": [
      "open",
      "high",
      "low",
      "close",
      "volume",
      "count",
      "quote_volume"
    ],
    "min_symbol_bars": 168,
    "cs_quantile_gte": {
      "col": "quote_volume",
      "q": 0.2
    }
  }
}
