{
  "version": "1",
  "dialect": "duckdb-factor-v1",
  "evaluation_type": "cross_sectional",
  "data_source": "yhydev97/quant-data",
  "signal_sql": "ABS(open / NULLIF(LAG(close, 1) OVER w, 0) - 1) - SIGN(open / NULLIF(LAG(close, 1) OVER w, 0) - 1) * ((close - open) / NULLIF(open, 0))",
  "postprocess": "cs_rank",
  "universe": {
    "dropna": [
      "open",
      "high",
      "low",
      "close"
    ],
    "min_symbol_bars": 168,
    "cs_quantile_gte": {
      "col": "quote_volume",
      "q": 0.2
    }
  }
}
